{
	"name": "todolist",
	"displayName": "Todo List",
	"description": "TodoList TreeView GUI.",
	"publisher": "saber2pr",
	"license": "MIT",
	"version": "0.1.4",
	"engines": {
		"vscode": "^1.56.0"
	},
	"categories": [
		"Other",
		"Notebooks",
		"Visualization"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Saber2pr/vsc-ext-todolist.git"
	},
	"icon": "assets/logo.png",
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "todolist.main",
				"title": "Todo List"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "yarn run compile",
		"lint": "tsc --noEmit",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"build": "vsce package",
		"release": "standard-version"
	},
	"devDependencies": {
		"@types/nconf": "^0.10.0",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.56.0",
		"standard-version": "^9.3.1",
		"typescript": "^4.1.3"
	},
	"dependencies": {
		"@saber2pr/vscode-webview": "^0.0.5",
		"nconf": "^0.11.2"
	}
}
