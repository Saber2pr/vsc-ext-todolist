{
	"name": "todolist",
	"displayName": "Todo List",
	"description": "Check Todo List.",
	"publisher": "saber2pr",
	"version": "0.0.2",
	"engines": {
		"vscode": "^1.56.0"
	},
	"categories": [
		"Other"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Saber2pr/vsc-ext-todolist.git"
	},
	"icon": "assets/logo.png",
	"activationEvents": [
		"*"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "todolist.main",
				"title": "Todo List"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "yarn run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"build": "vsce package"
	},
	"devDependencies": {
		"@types/nconf": "^0.10.0",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.56.0",
		"typescript": "^4.1.3"
	},
	"dependencies": {
		"@saber2pr/vscode-webview": "^0.0.5",
		"@types/axios": "^0.14.0",
		"@types/qs": "^6.9.6",
		"axios": "^0.21.1",
		"nconf": "^0.11.2",
		"qs": "^6.10.1"
	}
}